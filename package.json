{
  "name": "anon-inbox",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:unit": "pnpm --filter @anon-inbox/tests test:unit",
    "test:integration": "pnpm --filter @anon-inbox/tests test:integration",
    "test:e2e": "playwright test --config=tests/e2e/web/playwright.config.ts",
    "test:load": "k6 run tests/load/scenarios/global-send-rate.js",
    "lint": "turbo lint",
    "db:migrate": "turbo db:migrate",
    "db:generate": "turbo db:generate",
    "railway:build:api": "pnpm --filter @anon-inbox/api build",
    "railway:start:api": "pnpm --filter @anon-inbox/api start",
    "railway:build:web": "pnpm --filter @anon-inbox/web build",
    "railway:start:web": "pnpm --filter @anon-inbox/web start",
    "railway:build:admin": "pnpm --filter @anon-inbox/admin build",
    "railway:start:admin": "pnpm --filter @anon-inbox/admin start",
    "railway:build:worker-moderation": "pnpm --filter @anon-inbox/worker-moderation build",
    "railway:start:worker-moderation": "pnpm --filter @anon-inbox/worker-moderation start",
    "railway:build:worker-push": "pnpm --filter @anon-inbox/worker-push build",
    "railway:start:worker-push": "pnpm --filter @anon-inbox/worker-push start",
    "railway:build:worker-prompts": "pnpm --filter @anon-inbox/worker-prompts build",
    "railway:start:worker-prompts": "pnpm --filter @anon-inbox/worker-prompts start"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "playwright": "^1.49.1",
    "@playwright/test": "^1.49.1",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
