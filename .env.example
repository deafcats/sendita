# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/anon_inbox
DATABASE_URL_REPLICA=postgresql://user:password@localhost:5433/anon_inbox

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=90

# ─── Encryption (AES-256 for message bodies) ────────────────────────────────
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ─── IP Hash Salt (rotated daily via cron) ──────────────────────────────────
IP_HASH_SALT=your-daily-rotating-salt

# ─── Moderation ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
PERSPECTIVE_API_KEY=your-key

# ─── Push Notifications ──────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...

# ─── hCaptcha ────────────────────────────────────────────────────────────────
HCAPTCHA_SECRET=your-secret
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-site-key

# ─── FingerprintJS ───────────────────────────────────────────────────────────
NEXT_PUBLIC_FPJS_PUBLIC_KEY=your-public-key

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
APP_STORE_URL=https://apps.apple.com/app/id...
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=...

# ─── NCMEC (CSAM Reporting) ──────────────────────────────────────────────────
NCMEC_API_KEY=your-key
NCMEC_ORG_ID=your-org-id

# ─── Analytics ───────────────────────────────────────────────────────────────
TINYBIRD_API_KEY=your-key
TINYBIRD_API_URL=https://api.tinybird.co

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_IP_ALLOWLIST=127.0.0.1,::1
